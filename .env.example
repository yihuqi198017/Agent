# 应用
APP_NAME=enterprise-ai-agent
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# OpenAI / 兼容 API
OPENAI_API_KEY=sk-your-key
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agent_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_COLLECTION_NAME=agent_knowledge
ENABLE_EMBEDDING_UPLOAD=true

# 医疗分诊
TRIAGE_RETENTION_DAYS=7
TRIAGE_TOP_K=6
TRIAGE_MAX_CHUNKS=1200

# 日志
LOG_LEVEL=INFO
